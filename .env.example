DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nursing_support"
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# 公開ページの集客SEO・OGP・sitemap で使う本番の絶対URL（末尾スラッシュ不要）
# 未設定時は NEXTAUTH_URL → http://localhost:3000 の順でフォールバック
NEXT_PUBLIC_SITE_URL="https://example.com"

# メール送信（Brevo SMTP）。未設定時はコンソールログにフォールバック
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# お問い合わせ送信先（システム管理者）
SUPPORT_EMAIL=""
