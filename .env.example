# ホスト型PostgreSQLは末尾に ?sslmode=require を付与すること
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nursing_support"

# 【本番必須】セッションJWTの署名鍵。強いランダム値を生成して設定する:
#   openssl rand -base64 32
# 未設定/プレースホルダのままだと本番では起動時にエラーになる（lib/env.ts）
NEXTAUTH_SECRET="your-secret-key-here"

# 【本番必須】公開URL（末尾スラッシュ無し）。パスワード再設定リンク等の生成に使用
NEXTAUTH_URL="http://localhost:3000"

# 公開ページの集客SEO・OGP・sitemap で使う本番の絶対URL（末尾スラッシュ不要）
# 未設定時は NEXTAUTH_URL → http://localhost:3000 の順でフォールバック
NEXT_PUBLIC_SITE_URL="https://example.com"

# メール送信（Brevo SMTP）。未設定時はコンソールログにフォールバック
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# お問い合わせ送信先（システム管理者）
SUPPORT_EMAIL=""
